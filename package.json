{
  "name": "vue-pincher",
  "author": {
    "name": "Evgenii Ilin",
    "email": "ievgeniy88@gmail.com"
  },
  "description": "Vue 3 image cropper component",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ievgeniy88/vue-pincher/issues"
  },
  "homepage": "https://github.com/ievgeniy88/vue-pincher#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ievgeniy88/vue-pincher.git"
  },
  "keywords": [
    "vue",
    "vue3",
    "image cropper",
    "picture cropper",
    "photo cropper",
    "image cropper",
    "cropper",
    "crop",
    "pan",
    "zoom",
    "pinch"
  ],
  "version": "0.2.6",
  "private": false,
  "type": "module",
  "files": [
    "dist"
  ],
  "module": "./dist/vue-pincher.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/vue-pincher.js"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "start": "vite",
    "lint": "eslint ./",
    "lint:fix": "eslint ./ --fix",
    "build": "vite build && vue-tsc -p tsconfig.lib.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run --coverage",
    "test:dev": "vitest",
    "prepare": "husky"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8",
    "vue": "^3.5.35",
    "vue-tsc": "^3.3.3"
  }
}
